source "https://rubygems.org"

# Use the github-pages gem to match GitHub's environment
gem "github-pages", "~> 231", group: :jekyll_plugins

# Explicitly add the theme for the build environment
gem "minimal-mistakes-jekyll"

gem "tzinfo-data"
gem "wdm", "~> 0.1.0" if Gem.win_platform?

group :jekyll_plugins do
  gem "jekyll-paginate"
  gem "jekyll-sitemap"
  gem "jekyll-gist"
  gem "jekyll-feed"
  gem "jemoji"
  gem "jekyll-include-cache"
end